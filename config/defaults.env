# Reconix defaults (safe to commit - no secrets)
RECONIX_VERSION="1.0.0"

DEFAULT_THREADS=50
DEFAULT_TIMEOUT=10
DEFAULT_OUTPUT_DIR="${RECONIX_ROOT}/output"
LOG_LEVEL=INFO
DEBUG=false
DRY_RUN=false
INTERACTIVE=true
MAX_RETRIES=3
RETRY_BACKOFF=2
MAX_PARALLEL=4
NOTIFY_LEVEL=INFO

TOOLS_DIR="${HOME}/tools"
NUCLEI_TEMPLATES="${TOOLS_DIR}/nuclei-templates"
CORP_ROOT_DIR="${HOME}/work/corps"
BUG_BOUNTY_HEADER="x-bug-bounty: hacker"

# Remote VPS (override in user config)
VPS_WORK_DIR="~/work/corps"
VPS_SSH_KEY="${HOME}/.ssh/id_rsa"

# Wordlists
JOHN_WORDLIST="/usr/share/wordlists/rockyou.txt"
HASHCAT_WORDLIST="/usr/share/wordlists/rockyou.txt"
HASHCAT_RULES="/usr/share/hashcat/rules/best64.rule"
